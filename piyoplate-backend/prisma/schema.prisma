generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model users {
id                  Int              @id @default(autoincrement())
  username            String           @unique(map: "username") @db.VarChar(50)
  email               String           @unique(map: "email") @db.VarChar(100)
  password            String           @db.VarChar(255)
  full_name           String?          @db.VarChar(100)
  daily_calorie_goal  Int              @default(2000)
  created_at          DateTime         @default(now()) @db.Timestamp(0)
  updated_at          DateTime         @default(now()) @db.Timestamp(0)
  role                users_role?      @default(user)

  daily_calorie_target  Int      @default(2000) // Default rata-rata manusia
  weight                Float?   // Dalam kg
  height                Float?   // Dalam cm

  recipes             recipes[]
  nutrition_logs      nutrition_logs[]
  reviews             reviews[]
  bookmarks           bookmarks[]
}

model recipes {
  id                   Int              @id @default(autoincrement())
  author_id            Int              // Pembuat resep
  title                String           @db.VarChar(100)
  cuisine_type         String?          @db.VarChar(50) // Tambahan spek: jenis masakan
  description          String?          @db.Text
  calories_per_serving Int
  cook_time_minutes    Int?
  ingredients          String           @db.Text // Bisa disimpan dalam format JSON string
  instructions         String           @db.Text
  image_url            String?          @db.VarChar(255) // URL foto dari Cloud Storage
  video_url            String?          @db.VarChar(255) // URL video dari Cloud Storage
  created_at           DateTime         @default(now()) @db.Timestamp(0)
  updated_at           DateTime         @default(now()) @db.Timestamp(0)
  reviews              reviews[]
  bookmarks            bookmarks[]
  nutrition_logs       nutrition_logs[]

  author               users            @relation(fields: [author_id], references: [id])
}

model nutrition_logs {
  id             Int      @id @default(autoincrement())
  user_id        Int
  recipe_id      Int?     // Dibikin opsional (?) biar bisa "Quick Add"
  food_name      String?  // Untuk fitur Quick Add (isi manual)
  calories_added Int
  logged_at      DateTime @default(now()) @db.Timestamp(0)

  user           users    @relation(fields: [user_id], references: [id])
  recipe         recipes? @relation(fields: [recipe_id], references: [id])
}

enum users_role {
  admin
  user
}

model reviews {
  id        Int      @id @default(autoincrement())
  user_id   Int
  recipe_id Int
  rating    Int      // 1-5
  comment   String?  @db.Text
  createdAt DateTime @default(now())

  user      users    @relation(fields: [user_id], references: [id])
  recipe    recipes  @relation(fields: [recipe_id], references: [id])
}

model bookmarks {
  id        Int      @id @default(autoincrement())
  user_id   Int
  recipe_id Int
  createdAt DateTime @default(now())

  user      users    @relation(fields: [user_id], references: [id])
  recipe    recipes  @relation(fields: [recipe_id], references: [id])
}